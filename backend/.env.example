# =============================================================================
# DEVELOPMENT — copy to backend/.env for local work
# =============================================================================
PORT=3001
NODE_ENV=development

# MongoDB (local):
# MONGODB_URI=mongodb://127.0.0.1:27017/pineneedledesigns
#
# MongoDB (DigitalOcean — Public network, for your PC only):
# IMPORTANT: use /pineneedledesigns (NOT /admin)
# MONGODB_URI=mongodb+srv://doadmin:YOUR_PASSWORD@HOST/pineneedledesigns?authSource=admin&replicaSet=REPLICA_SET&tls=true
MONGODB_URI=mongodb://127.0.0.1:27017/pineneedledesigns

SESSION_SECRET=local-development-only
APP_BASE_URL=http://localhost:5173

# PayPal (use SANDBOX_* locally)
PAYPAL_BOOKING_DEPOSITS_ENABLED=false
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
SANDBOX_PAYPAL_CLIENT_ID=
SANDBOX_PAYPAL_CLIENT_SECRET=

# Email (local: Gmail SMTP; leave RESEND empty)
RESEND_API_KEY=
RESEND_FROM=orders@pineneedledesigns.store
EMAIL=
EMAIL_APP_PASSWORD=
ORDER_EMAILS=

# =============================================================================
# PRODUCTION — do NOT put these in backend/.env on the server
# Set them as GitHub Actions Secrets (Settings → Secrets and variables → Actions)
# Deploy workflow injects them into PM2 on the DigitalOcean Droplet
# =============================================================================
#
# Required GitHub Secrets:
#
# DO_HOST                  = Droplet IP or hostname
# DO_USER                  = SSH user (usually root)
# DO_SSH_KEY               = Private SSH key
# MONGODB_URI              = VPC/private connection string (see below)
# SESSION_SECRET           = Long random string (not "local-development-only")
# RESEND_API_KEY           = re_... from resend.com
#
# Optional GitHub Secrets:
#
# PAYPAL_BOOKING_DEPOSITS_ENABLED = true or false
# PAYPAL_CLIENT_ID                  = Live PayPal client ID
# PAYPAL_CLIENT_SECRET              = Live PayPal secret
#
# Optional GitHub Variable (not secret):
#
# RESEND_FROM = orders@pineneedledesigns.store
#
# Production MONGODB_URI (DigitalOcean → Databases → VPC network → Connection string):
# Use database name pineneedledesigns (not admin)
# Example:
# mongodb+srv://doadmin:YOUR_PASSWORD@private-db-mdb-nyc1-46265-XXXX.mongo.ondigitalocean.com/pineneedledesigns?authSource=admin&replicaSet=db-mdb-nyc1-46265&tls=true
#
# Production defaults (no secret needed — set by deploy workflow / code):
# NODE_ENV=production
# APP_BASE_URL=https://pineneedledesigns.store
# PORT=3001
