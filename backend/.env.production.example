# Reference only — copy values into GitHub Actions Secrets
# Repo: Settings → Secrets and variables → Actions → New repository secret

DO_HOST=
DO_USER=root
DO_SSH_KEY=

# DigitalOcean MongoDB — VPC/private connection string (server and DB on same VPC)
# Connection details → VPC network → Connection string
# IMPORTANT: database name must be pineneedledesigns (NOT admin)
# Example public (local only):
# mongodb+srv://doadmin:PASSWORD@db-mdb-....mongo.ondigitalocean.com/pineneedledesigns?authSource=admin&replicaSet=db-mdb-nyc1-46265&tls=true
# Example VPC (production Droplet):
MONGODB_URI=mongodb+srv://doadmin:YOUR_PASSWORD@private-HOST.mongo.ondigitalocean.com/pineneedledesigns?authSource=admin&replicaSet=db-mdb-nyc1-46265&tls=true

# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
SESSION_SECRET=

# Cloudflare Zero Trust Access application settings (not secrets).
CLOUDFLARE_ACCESS_TEAM_DOMAIN=chrismuha.cloudflareaccess.com
CLOUDFLARE_ACCESS_AUD=3d74f00031bbb04310c544962709dc773d85c1c71c7fd1c86d6d2b4ce14df5eb

RESEND_API_KEY=
RESEND_FROM=orders@pineneedledesigns.store

PAYPAL_BOOKING_DEPOSITS_ENABLED=false
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
